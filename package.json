{
  "name": "clanker-blocker",
  "version": "0.1.0",
  "description": "Auto-block identified bot accounts from the UnsafeLabs/Bounty-Hunters clankers list",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/action.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "dev": "tsx src/index.ts",
    "action": "tsx src/action.ts",
    "lint": "eslint src/",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "github",
    "blocking",
    "action",
    "app",
    "bot-detection"
  ],
  "author": "billythekid",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
